# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=financial_manager
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration (use a strong random secret, e.g.: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_USE_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# AI Configuration (Google Gemini)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# CORS (comma-separated allowed origins, NEVER use *)
CORS_ORIGIN=http://localhost:4200,http://localhost:8081

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY

# Email (SMTP) - Optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
